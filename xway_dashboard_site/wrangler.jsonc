{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "xway-dashboard-site",
  "pages_build_output_dir": "./dist",
  "compatibility_date": "2026-04-04",
  "vars": {
    "XWAY_DEFAULT_ARTICLES": "44392513,60149847",
    "XWAY_CACHE_NAMESPACE": "xway-production"
  },
  "kv_namespaces": [
    {
      "binding": "XWAY_AI_CACHE",
      "id": "30375e32cbf24daf9f53361ef7a552d3"
    }
  ],
  "d1_databases": [
    {
      "binding": "XWAY_SHARED_CACHE_DB",
      "database_name": "xway-shared-cache",
      "database_id": "88330933-f846-4fa8-bbff-50143e566693"
    }
  ]
  // Configure in Cloudflare dashboard or via wrangler secrets:
  // - API_ORIGIN: optional reserve proxy origin for routes not handled by Pages Functions
  // - XWAY_STORAGE_STATE_JSON or XWAY_STORAGE_STATE_BASE64: auth state for native XWAY API calls
  // - XWAY_AI_API_KEY: required Bearer token for shared ChatGPT Actions
  // - OPENAI_API_KEY: optional, required for the in-site /ai chat
  // - OPENAI_MODEL: optional model override for /api/ai/chat
  // - MPVIBE_REFRESH_COOKIE_HEADER, MPVIBE_COOKIE_HEADER, or MPVIBE_AUTHORIZATION: optional MPVibe data source for AI analytics
  // - PACHKA_ACCESS_TOKEN: Pachka bot token with messages:create scope
  // - PACHKA_ENTITY_ID or PACHKA_CHAT_ID: Pachka chat/user/thread id for the daily report
  // - PACHKA_ENTITY_TYPE: optional Pachka entity type, defaults to discussion
  // - PACHKA_REPORT_SECRET: shared secret for /api/pachka-report/send and the cron worker
  // - PACHKA_REPORT_DAYS, PACHKA_REPORT_LIMIT, PACHKA_REPORT_STOCK_MIN_VALUE, PACHKA_REPORT_TIMEZONE_OFFSET_MINUTES: optional report controls
  // - PACHKA_REPORT_MESSAGE_PREFIX, PACHKA_REPORT_DASHBOARD_URL, PACHKA_REPORT_ENABLED: optional Pachka report controls
  // - PACHKA_REPORT_AI_RECOMMENDATIONS, PACHKA_REPORT_AI_MODEL, PACHKA_REPORT_AI_REASONING_EFFORT, PACHKA_REPORT_AI_DEEP_LIMIT: optional AI recommendation controls
  // - WB_FEEDBACK_ROOTS_JSON: optional article -> WB feedback root id mapping
  // - XWAY_AI_CACHE: optional KV namespace binding for shared AI response cache, MPVibe token cache, and XWAY source cache
  // - XWAY_SHARED_CACHE_DB: optional D1 binding for shared API/source cache visible to all users
}
