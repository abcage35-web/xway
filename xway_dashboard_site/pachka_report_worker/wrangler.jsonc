{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "xway-pachka-report-cron",
  "main": "./src/worker.js",
  "compatibility_date": "2026-04-04",
  "triggers": {
    "crons": [
      "0 6 * * *"
    ]
  },
  "vars": {
    "XWAY_PACHKA_REPORT_URL": "https://xway-bt4.pages.dev/api/pachka-report/send"
  }
}
